# ==========================================
# 通用大模型配置 (OpenAI 兼容协议)
# 适用于: OpenAI, DeepSeek, Qwen, GLM, Minimax 等
# ==========================================
# 默认启用此提供商
LLM_PROVIDER=openai

# 您的 API Key
OPENAI_API_KEY=your_api_key_here

# 代理地址或不同厂商的网关地址
# DeepSeek 示例: https://api.deepseek.com/v1
# Qwen 示例: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 使用的模型名称
# 示例: gpt-4o, deepseek-chat, qwen-max, glm-4
OPENAI_MODEL_NAME=gpt-4o
# Minimum delay between LLM request starts, in seconds. Example: 0.5 / 1 / 2
LLM_MIN_CALL_INTERVAL_SECONDS=0

# ==========================================
# Gemini 专属配置 (Google Native API)
# ==========================================
# 若要使用 Gemini，请将上面的 LLM_PROVIDER 改为 gemini
# LLM_PROVIDER=gemini

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash

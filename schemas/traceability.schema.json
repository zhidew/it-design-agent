{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Traceability Matrix Schema",
  "type": "object",
  "properties": {
    "project_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "traceability_links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "requirement_id": {
            "type": "string"
          },
          "requirement_desc": {
            "type": "string"
          },
          "design_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "test_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ops_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": ["fully_traced", "partially_traced", "missing_design", "missing_test"]
          }
        },
        "required": ["requirement_id", "design_artifacts", "test_artifacts", "status"]
      }
    },
    "missing_links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["project_name", "traceability_links"]
}

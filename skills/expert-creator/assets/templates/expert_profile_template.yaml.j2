# Expert Profile Template
# Generated by Expert Creator

name: {{ expert_name }}
capability: {{ expert_id }}
description: "{{ description }}"
version: 0.1.0
skills:
  - {{ expert_id }}
scheduling:
  priority: {{ priority | default(50) }}
  dependencies: {{ dependencies | default([]) }}
keywords: {{ keywords | default([]) }}
tools:
  allowed: {{ tools | default(["list_files", "read_file_chunk", "grep_search", "write_file"]) }}
outputs:
  expected: {{ outputs | default(["output.md"]) }}
policies:
  asset_baseline_required: {{ asset_baseline_required | default(true) }}
  evidence_required: {{ evidence_required | default(true) }}
  output_must_be_structured: {{ output_must_be_structured | default(true) }}
